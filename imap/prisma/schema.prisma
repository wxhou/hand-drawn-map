generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Prompt {
  id           String   @id @default(cuid())
  title        String
  description  String?
  promptText   String
  imageUrl     String
  category     String
  authorName   String
  authorAvatar String?
  likeCount    Int      @default(0)
  viewCount    Int      @default(0)
  isFeatured   Boolean  @default(false)
  source       String   @default("user_submit")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  icon  String
  order Int    @default(0)
}
